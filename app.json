{
  "expo": {
    "name": "Sentinel",
    "slug": "sentinel-mobile",
    "version": "1.0.0",
    "scheme": "sentinel",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#051205",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.renaissance.sentinel"
    },
    "android": {
      "package": "com.renaissance.sentinel",
      "adaptiveIcon": {
        "backgroundColor": "#051205",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Sentinel needs your location to attach coordinates to incident reports."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Sentinel needs camera access to attach photos to incident reports."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sentinel needs photo library access to attach evidence images."
        }
      ]
    ],
    "extra": {
      "API_BASE_URL": "http://192.168.1.100:3001",
      "MOCK_MODE": true,
      "router": {},
      "eas": {
        "projectId": "31068b1b-ef03-4fa1-b97b-3979ca939ea3"
      }
    }
  }
}
